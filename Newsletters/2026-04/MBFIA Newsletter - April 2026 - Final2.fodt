     <table:table-row>
      <table:table-cell table:style-name="Table7.A1" office:value-type="string">
       <text:p text:style-name="Table_20_Contents"/>
      </table:table-cell>
      <table:table-cell table:style-name="Table7.A1" office:value-type="string">
       <text:p text:style-name="P6">April 2026 Quarterly Newsletter</text:p>
      </table:table-cell>
      <table:table-cell table:style-name="Table7.A1" office:value-type="string">
       <text:p text:style-name="Table_20_Contents"/>
      </table:table-cell>
     </table:table-row>
    </table:table>
    <text:p text:style-name="Header_20_left"/>
   </style:header-first>
  </style:master-page>
 </office:master-styles>
 <office:body>
  <office:text text:use-soft-page-breaks="true">
   <office:forms form:automatic-focus="false" form:apply-design-mode="false"/>
   <text:sequence-decls>
    <text:sequence-decl text:display-outline-level="0" text:name="Illustration"/>
    <text:sequence-decl text:display-outline-level="0" text:name="Table"/>
    <text:sequence-decl text:display-outline-level="0" text:name="Text"/>
    <text:sequence-decl text:display-outline-level="0" text:name="Drawing"/>
    <text:sequence-decl text:display-outline-level="0" text:name="Figure"/>
   </text:sequence-decls>
   <text:section text:style-name="Sect1" text:name="Section1">
    <text:h text:style-name="P242" text:outline-level="1"><text:bookmark-start text:name="__RefHeading___Toc1177_2834373222"/>Welcome Back!<text:bookmark-end text:name="__RefHeading___Toc1177_2834373222"/></text:h>
    <text:p text:style-name="P153"><text:span text:style-name="T39">Nearly 500 friends of the McArthur-Burney Falls Interpretive Association have subscrribed to our newsletter in the past. </text:span><text:span text:style-name="T3">The ‘quarterly’ newsletter from MBFIA has </text:span><text:span text:style-name="T39">been sporadic</text:span><text:span text:style-name="T3"> in recent years. We plan to revivie this tradtion and </text:span><text:span text:style-name="T39">do our best to </text:span><text:span text:style-name="T3">stick to a quarterly schedule. This newsletter is scheduled for early </text:span><text:span text:style-name="T21">April</text:span><text:span text:style-name="T3"> and you can expec</text:span><text:span text:style-name="T81">t</text:span><text:span text:style-name="T3"> to see the next one in early </text:span><text:span text:style-name="T21">July</text:span><text:span text:style-name="T3"> as America celebrates the <text:s/></text:span>Semiquincentennial<text:span text:style-name="T3"> of the signing of </text:span><text:span text:style-name="T39">our</text:span><text:span text:style-name="T3"> Declaration of Ind</text:span><text:span text:style-name="T6">e</text:span><text:span text:style-name="T3">pend</text:span><text:span text:style-name="T6">e</text:span><text:span text:style-name="T3">nce. </text:span><text:span text:style-name="T15">In the </text:span><text:span text:style-name="T22">October</text:span><text:span text:style-name="T15"> newsletter we will look forward to Heritage day. And to finish the year, the </text:span><text:span text:style-name="T22">January</text:span><text:span text:style-name="T15"> 2027 newsletter will start the Centennial celebration of the McArthur-Burney Falls Memorial State Park.</text:span></text:p>
    <text:h text:style-name="P29" text:outline-level="1"><text:bookmark-start text:name="__RefHeading___Toc1179_2834373222"/>Upcoming Dates <text:span text:style-name="T70">in 2026</text:span><text:bookmark-end text:name="__RefHeading___Toc1179_2834373222"/></text:h>
    <text:list text:style-name="L1">
     <text:list-item>
      <text:p text:style-name="P284">April 1 – <text:span text:style-name="T81">Seasonal openings begin.</text:span></text:p>
     </text:list-item>
     <text:list-item>
      <text:p text:style-name="P287"><text:span text:style-name="T94">Friday, </text:span>April <text:span text:style-name="T94">3</text:span> – <text:s/>Visitor Center and Store open</text:p>
     </text:list-item>
     <text:list-item>
      <text:p text:style-name="P285">Sunday, April 5 – Easter</text:p>
     </text:list-item>
     <text:list-item>
      <text:p text:style-name="P288">Friday, May 1<text:span text:style-name="T16"> – </text:span>Season opens at the Falls</text:p>
     </text:list-item>
     <text:list-item>
      <text:p text:style-name="P288">Friday, May 1<text:span text:style-name="T100">5</text:span><text:span text:style-name="T16"> – </text:span><text:span text:style-name="T100">Reserved camping starts</text:span></text:p>
     </text:list-item>
     <text:list-item>
      <text:p text:style-name="P296"><text:span text:style-name="T41">Friday, May 22-Sund</text:span><text:span text:style-name="T49">ay, May 24 – Memorial Day Weekend </text:span><text:span text:style-name="T80">(Warning: Very busy roads.)</text:span></text:p>
     </text:list-item>
     <text:list-item>
      <text:p text:style-name="P289">Monday, May 25<text:span text:style-name="T16"> – </text:span>Memorial Day (adjusted)</text:p>
     </text:list-item>
     <text:list-item>
      <text:p text:style-name="P289"><draw:frame draw:style-name="fr13" draw:name="Image3" text:anchor-type="char" svg:y="0.2299in" svg:width="1in" svg:height="0.6in" draw:z-index="36"><draw:image draw:mime-type="image/svg+xml">
