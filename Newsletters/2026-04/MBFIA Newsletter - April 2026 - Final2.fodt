     <text:list-item>
      <text:p text:style-name="P286"><text:span text:style-name="T78">Sunday, </text:span><text:span text:style-name="T16">October </text:span>11 <text:span text:style-name="T16">– </text:span><text:span text:style-name="T71">McArthur-Burney Falls </text:span><text:span text:style-name="T74">Heritage Day Celebration</text:span></text:p>
