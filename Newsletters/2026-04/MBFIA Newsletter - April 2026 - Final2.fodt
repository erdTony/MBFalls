      </draw:image>
     </draw:frame>At the center, <text:span text:style-name="T99">you will find</text:span> these items for sale:</text:p>
    <text:list text:style-name="L14">
     <text:list-item>
      <text:p text:style-name="P305"><text:span text:style-name="T47">T-</text:span><text:span text:style-name="T46">Shirts </text:span></text:p>
