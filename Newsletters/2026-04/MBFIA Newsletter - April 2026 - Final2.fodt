     <text:list-item>
      <text:p text:style-name="P290">Monday, September 7<text:span text:style-name="T16"> – </text:span>Labor Day</text:p>
     </text:list-item>
     <text:list-item>
      <text:p text:style-name="P286"><text:span text:style-name="T78">Saturday, </text:span><text:span text:style-name="T16">September </text:span>12<text:span text:style-name="T16"> – </text:span><text:span text:style-name="T71">MBFIA </text:span><text:span text:style-name="T74">Volunteer </text:span><text:span text:style-name="T75">Appreciation </text:span><text:span text:style-name="T76">Day</text:span><text:span text:style-name="T31"> &amp; </text:span><text:span text:style-name="T16">Lunch</text:span></text:p>
